if exclusion1.upper() == "Y":
    exclusionname1 = input("Enter the first name of the first student: ")
    exclusionname2 = input("Enter the first name of the second student: ")

    exclusionname1 = exclusionname1.lower().capitalize()
    exclusionname2 = exclusionname2.lower().capitalize()


