students = ["Andrew", "Dylan", "James", "Kevin", "Nick", "Tyler", "Thomas", "Christopher", "Ryan", "Chris", "Daisy", "Jennifer", "Jessica", "Hailey", "Megan", "Lauren", "Taylor", "Kayla", "Rose", "Emma"]


